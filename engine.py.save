                "unstructured_chart_note": (
                    f"Patient presented with complaints of {random.choice(self.symptoms)} and minor physical discomfort. "
                    f"Prior history was evaluated, and patient was advised to follow up in 2 weeks."
                ),
                "vitals_logged": {
                    "blood_pressure": f"{random.randint(105, 140)}/{random.randint(65, 92)}",
                    "heart_rate_bpm": random.randint(55, 110),
                    "temp_fahrenheit": round(random.uniform(97.0, 103.2), 1)
                }
            },
            "billing_claim_submitted": {
                "claim_id": f"CLM-{random.randint(10000000, 99999999)}",
                "billed_cpt_code": random.choice(self.cpt_codes),
                "diagnosis_icd_codes": random.sample(self.icd_codes, random.randint(1, 3)),
                "charged_amount": round(random.uniform(75.0, 3250.0), 2)
            }
        }
