


import random
import time
from typing import Dict, List, Any, Optional
from pymongo import MongoClient
from pymongo.errors import ConnectionFailure, PyMongoError

class DBConnector:
    """
    Manages connections and basic CRUD operations with MongoDB.
    Decoupled design allows any schema to pass through dynamically.
    Fully compatible with PyMongo 4.x truthiness constraints.
    """
    def __init__(self, host: str = "localhost", port: int = 27017, db_name: str = "portfolio_engine"):
        self.host = host
        self.port = port
        self.db_name = db_name
        self.client = None
        self.db = None

    def connect(self) -> bool:
        """Establishes and verifies database connection."""
        try:
            connection_url = f"mongodb://{self.host}:{self.port}/"
            self.client = MongoClient(connection_url, serverSelectionTimeoutMS=3000)
            self.client.admin.command("ping")
            self.db = self.client[self.db_name]
            return True
        except ConnectionFailure:
            return False

    def insert_record(self, collection_name: str, data: Dict[str, Any]) -> Optional[str]:
        """Inserts a single document (nested dictionary) into a collection."""
        if self.db is None:
            raise RuntimeError("Database not connected. Call connect() first.")
        try:
            collection = self.db[collection_name]
            result = collection.insert_one(data)
            return str(result.inserted_id)
        except PyMongoError as e:
            print(f"❌ MongoDB Insertion Error: {e}")
            return None

    def insert_many_records(self, collection_name: str, dataset: List[Dict[str, Any]]) -> bool:
        """Inserts multiple documents efficiently in a single batch transaction."""
        if self.db is None:
            raise RuntimeError("Database not connected. Call connect() first.")
        try:
            collection = self.db[collection_name]
            collection.insert_many(dataset)
            return True
        except PyMongoError as e:
            print(f"❌ MongoDB Batch Insertion Error: {e}")
            return False

    def query_records(self, collection_name: str, query: Dict[str, Any]) -> List[Dict[str, Any]]:
        """Queries database for documents matching filter criteria."""
        if self.db is None:
            raise RuntimeError("Database not connected. Call connect() first.")
        try:
            collection = self.db[collection_name]
            return list(collection.find(query))
        except PyMongoError as e:
            print(f"❌ MongoDB Query Error: {e}")
            return []

    def create_collection_index(self, collection_name: str, field_name: str) -> str:
        """Creates an index tree on a specific field to accelerate search queries."""
        if self.db is None:
            raise RuntimeError("Database not connected. Call connect() first.")
        try:
            collection = self.db[collection_name]
            return collection.create_index([(field_name, 1)])
        except PyMongoError as e:
            print(f"❌ MongoDB Indexing Error: {e}")
            return ""

    def drop_collection(self, collection_name: str):
        """Drops a collection to wipe the environment clean between test runs."""
        if self.db is not None:
            self.db[collection_name].drop()

    def close(self):
        """Closes the client connection."""
        if self.client:
            self.client.close()


class DataGenerator:
    """
    Enterprise Data Printing Press. Generates millions of unique permutations
    of multi-layered, nested JSON structures for all six target portfolio projects.
    """
    def __init__(self):
        # Global high-cardinality metadata pools
        self.patient_first_names = [
            "Sarah", "Michael", "Elena", "Marcus", "David", "Aaliyah", 
            "Amara", "Yusuf", "Keiko", "Mateo", "Priya", "Dmitri", 
            "Chloe", "Kwame", "Sofia", "Arjun", "Fatima", "Leila", 
            "Oliver", "Santiago", "Ji-Woo", "Emily", "Carlos", "Amina"
        ]
        self.patient_last_names = [
            "Smith", "Chen", "Rodriguez", "Johnson", "Patel", "Kim", 
            "Osei", "Silva", "Nakamura", "Gomez", "Gupta", "Ivanov", 
            "Dubois", "Haddad", "Müller", "Ali", "Singh", "Hernandez"
        ]
        
        # 1. Payment Integrity Data Parameters
        self.low_intensity_symptoms = [
            "minor dry cough", "mild seasonal allergies", "slight runny nose", 
            "minor paper cut", "routine health checkup consultation", "recurrent mild fatigue"
        ]
        self.high_intensity_symptoms = [
            "acute substernal chest pain", "unconscious unresponsive state", 
            "severe compound bone fracture", "stroke symptomatology", "septic shock conditions"
        ]
        
        # 2. Cloud FinOps Data Parameters
        self.cloud_providers = ["AWS", "GoogleCloud", "Azure"]
        self.instance_types = ["t3.medium", "m5.large", "r5.2xlarge", "n2-standard-4", "Standard_D4_v5", "c6i.4xlarge"]
        self.departments = ["Engineering", "FinTech-Core", "AI-Inference-Layer", "Staging-QA", "Marketing-Analytics"]
        self.cloud_services = ["EC2", "RDS", "S3", "KubernetesPod", "BigQuery", "CosmosDB", "LambdaFunction"]

        # 3. Commercial Due Diligence Data Parameters
        self.saas_industries = ["Retail", "FinTech", "Healthcare", "EdTech", "Logistics", "Cybersecurity"]
        self.support_ticket_categories = ["billing_dispute", "system_latency", "feature_request", "onboarding_friction"]
        self.churn_indicators = [
            "System is too slow and crashes during payroll processing.",
            "Pricing increased by 20% without warning. Looking at alternatives.",
            "Customer support ticket has been open for 3 weeks with zero response.",
            "Love the product but our team size downsized by half.",
            "Platform UI is extremely confusing to our new employees."
        ]

    def _generate_middle_initial(self) -> str:
        return random.choice(["A.", "M.", "T.", "R.", "J.", "E.", "S.", "K.", "L.", " "])

    # =========================================================================
    # PROJECT 1 & 2: Pre-Pay "Shift-Left" Payment Integrity Engine (Healthcare)
    # =========================================================================
    def generate_payment_integrity_record(self, record_id: int) -> Dict[str, Any]:
        """
        Generates clinical patient charts (EHR) paired with billing claims.
        Injects deliberate upcoding anomalies for machine learning detection,
        and includes high-dimensional vector search placeholders for semantic matching.
        """
        first_name = random.choice(self.patient_first_names)
        last_name = random.choice(self.patient_last_names)
        full_name = f"{first_name} {self._generate_middle_initial()} {last_name}".replace("  ", " ")
        
        is_upcoded_anomaly = random.choice([True, False])
        
        if is_upcoded_anomaly:
            symptom = random.choice(self.low_intensity_symptoms)
            duration_mins = random.randint(10, 15)
            ehr_notes = (
                f"Patient presented with {symptom}. Vitals are highly stable. "
                f"Evaluation completed in {duration_mins} minutes. Prescribed basic rest and over-the-counter medicine. "
                f"Discharged home in good spirits."
            )
            billed_cpt = "99215"
            charged_amount = round(random.uniform(950.0, 1450.0), 2)
            complexity_level = "Low"
        else:
            is_severe = random.choice([True, False])
            if is_severe:
                symptom = random.choice(self.high_intensity_symptoms)
                duration_mins = random.randint(60, 95)
                ehr_notes = (
                    f"CRITICAL: Patient presented with {symptom}. Resuscitation protocol initiated. "
                    f"Complex diagnostic decision-making executed over {duration_mins} minutes. Team monitored patient continuously."
                )
                billed_cpt = "99215"
                charged_amount = round(random.uniform(950.0, 1450.0), 2)
                complexity_level = "High"
            else:
                symptom = random.choice(self.low_intensity_symptoms)
                duration_mins = random.randint(10, 15)
                ehr_notes = (
                    f"Patient presented with {symptom}. Dispatched routine checkup protocols. "
                    f"Discharged safely in {duration_mins} minutes."
                )
                billed_cpt = "99212"
                charged_amount = round(random.uniform(95.0, 180.0), 2)
                complexity_level = "Low"

        simulated_vector = [round(random.uniform(-1.0, 1.0), 4) for _ in range(8)]

        return {
            "record_id": record_id,
            "patient_name": full_name,
            "ehr_clinical_document": {
                "unstructured_chart_note": ehr_notes,
                "visit_duration_minutes": duration_mins,
                "clinical_complexity_extracted": complexity_level,
                "semantic_vector_embedding": simulated_vector
            },
            "billing_claim_submitted": {
                "provider_id": f"NPI-{random.randint(100000, 999999)}",
                "billed_cpt_code": billed_cpt,
                "charged_amount": charged_amount,
                "is_anomalous_upcoded": is_upcoded_anomaly
            }
        }

    def generate_healthcare_record(self, record_id: int) -> Dict[str, Any]:
        """Legacy compatibility alias to prevent breaking existing benchmark scripts."""
        return self.generate_payment_integrity_record(record_id)

    # =========================================================================
    # PROJECT 3 & 4: Multi-Cloud "Cloud Sprawl" & FinOps Optimizer (NoSQL/Log Tech)
    # =========================================================================
    def generate_finops_log(self, record_id: int) -> Dict[str, Any]:
        """
        Generates high-velocity, nested JSON server telemetry, cloud asset logs,
        and cost profiles across AWS, GCP, and Azure to model distributed big-data logs.
        """
        provider = random.choice(self.cloud_providers)
        service = random.choice(self.cloud_services)
        dept = random.choice(self.departments)
        
        cost_anomaly_active = random.choices([True, False], weights=[15, 85])[0]
        
        if cost_anomaly_active:
            daily_cost = round(random.uniform(500.0, 8500.0), 2)
            utilization_cpu_pct = round(random.uniform(1.0, 8.0), 2)
            status = "flagged_overspending"
        else:
            daily_cost = round(random.uniform(0.12, 45.00), 2)
            utilization_cpu_pct = round(random.uniform(45.0, 95.0), 2)
            status = "optimized"

        return {
            "record_id": record_id,
            "timestamp": time.time() - random.randint(0, 100000),
            "cloud_provider": provider,
            "resource_metadata": {
                "instance_id": f"i-{random.randint(100000, 999999)}x_xyz",
                "instance_type": random.choice(self.instance_types),
                "service_category": service,
                "associated_department": dept
            },
            "operational_metrics": {
                "cpu_utilization_pct": utilization_cpu_pct,
                "memory_used_gb": round(random.uniform(2.0, 64.0), 2),
                "network_traffic_in_out_gb": round(random.uniform(1.2, 500.0), 2)
            },
            "financial_layer": {
                "daily_cost_usd": daily_cost,
                "billing_status": status,
                "recommendation_engine": "shutdown_idle_asset" if cost_anomaly_active else "maintain"
            }
        }

    # =========================================================================
    # PROJECT 5 & 6: Commercial Due Diligence & Revenue Attrition Engine (PE)
    # =========================================================================
    def generate_commercial_due_diligence_record(self, record_id: int) -> Dict[str, Any]:
        """
        Generates SaaS enterprise customer metadata, recurring revenue streams (MRR),
        user engagement scores, and support ticket text to train retention/attrition models.
        """
        mrr = round(random.uniform(1500.0, 25000.0), 2)
        health_score = random.randint(20, 100)
        
        if health_score < 50:
            ticket_msg = random.choice(self.churn_indicators)
            category = random.choice(["billing_dispute", "system_latency"])
            churn_risk_label = 1
        else:
            ticket_msg = "Product is running smoothly. We would love to request a new API integration feature."
            category = "feature_request"
            churn_risk_label = 0

        return {
            "record_id": record_id,
            "customer_company_name": f"{random.choice(self.patient_last_names)} Global Technologies",
            "industry_sector": random.choice(self.saas_industries),
            "saas_financial_metrics": {
                "monthly_recurring_revenue_mrr": mrr,
                "annual_contract_value_acv": mrr * 12,
                "unbilled_receivables_outstanding": round(random.uniform(0.0, mrr * 0.5), 2)
            },
            "user_engagement": {
                "daily_active_users_dau": random.randint(5, 500),
                "system_health_score_index": health_score,
                "license_utilization_rate_pct": round(random.uniform(15.0, 100.0), 2)
            },
            "support_and_sentiment_analysis": {
                "last_ticket_category": category,
                "raw_ticket_text": ticket_msg,
                "customer_churn_risk_label": churn_risk_label
            }
        }
