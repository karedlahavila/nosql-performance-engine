    def generate_healthcare_record(self, record_id: int) -> Dict[str, Any]:
        first_name = random.choice(self.patient_first_names)
        middle = self._generate_middle_initial()
        last_name = random.choice(self.patient_last_names)
        full_name = f"{first_name} {middle} {last_name}".replace("  ", " ")
        
        birth_year = random.randint(1950, 2024)
        birth_month = f"{random.randint(1, 12):02d}"
        birth_day = f"{random.randint(1, 28):02d}"
        encounter_day = f"{random.randint(1, 28):02d}"
        
        return {
            "record_id": record_id,
            "patient_metadata": {
                "name": full_name,
                "dob": f"{birth_year}-{birth_month}-{birth_day}",
                "demographics": {
                    "gender": random.choice(["Male", "Female", "Non-binary", "Prefer not to say"]),
                    "language": random.choice(["English", "Spanish", "Mandarin", "French", "Arabic", "Hindi"])
                }
